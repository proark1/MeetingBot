# Copy to .env and fill in your values

# Required: Anthropic API key for Claude-powered meeting intelligence
ANTHROPIC_API_KEY=sk-ant-...

# How long (seconds) a simulated meeting runs before generating transcript+analysis
# Set low (e.g. 10) for quick demos, higher (e.g. 300) for realistic timing
BOT_SIMULATION_DURATION=60

# Optional overrides
# SECRET_KEY=change-me-in-production
# DATABASE_URL=sqlite+aiosqlite:///./meetingbot.db
