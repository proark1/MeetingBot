# JustHereToListen.io — example environment file
# Copy to backend/.env (gitignored) for local development.
# In production, set these via your platform's secret manager (e.g. Railway).

# ── Required ──────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
# Required when ENVIRONMENT=production/staging, DATABASE_URL is non-SQLite, or API_KEY is set.
ENCRYPTION_KEY=change-me-to-a-separate-long-random-string
DATABASE_URL=sqlite+aiosqlite:///./meetingbot.db
# DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/db   # production

# ── AI providers (at least one) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# ── Hosting / OpenAPI ─────────────────────────────────────────────────────────
# Set this in production so the published OpenAPI schema's `servers[0].url`
# points at your real host. Generated SDK clients hit the right URL out of the
# box. Leave blank in dev — schema falls back to http://localhost:8000.
PUBLIC_BASE_URL=
ENVIRONMENT=development

# ── CORS / proxy ──────────────────────────────────────────────────────────────
CORS_ORIGINS=*
TRUST_PROXY_HEADERS=false

# ── Admin access ──────────────────────────────────────────────────────────────
ADMIN_EMAILS=

# ── Optional integrations ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_BACKEND=local
S3_BUCKET=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ── Concurrency ───────────────────────────────────────────────────────────────
MAX_CONCURRENT_BOTS=3

# ── Synthetic canary ──────────────────────────────────────────────────────────
# Enable only after configuring persistent test meetings that admit the bot.
CANARY_ENABLED=false
CANARY_INTERVAL_S=1800
CANARY_BASE_URL=
CANARY_API_KEY=
CANARY_MEET_URL=
CANARY_ZOOM_URL=
CANARY_TEAMS_URL=
CANARY_ONEPIZZA_URL=
