#!/usr/bin/env bash
# Pre-commit hook: ensure documentation stays in sync.
#
# 1. Require README.md to be staged when API-surface files change.
# 2. Warn if VERSION / README.md / CHANGELOG.md have stale version or date.

set -euo pipefail

STAGED=$(git diff --cached --name-only)

# ── Check 1: API files require README update ──────────────────────────────────

api_changed=0
doc_changed=0

while IFS= read -r f; do
    case "$f" in
        backend/app/api/*.py \
        | backend/app/schemas/*.py \
        | backend/app/config.py \
        | backend/app/main.py)
            api_changed=1 ;;
        README.md)
            doc_changed=1 ;;
    esac
done <<< "$STAGED"

if [ "$api_changed" -eq 1 ] && [ "$doc_changed" -eq 0 ]; then
    echo ""
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  API files changed — README.md must be updated too.     ║"
    echo "║                                                          ║"
    echo "║  Staged API files:                                       ║"
    git diff --cached --name-only | grep -E \
        '^backend/app/(api|schemas)/.*\.py$|^backend/app/(config|main)\.py$' \
        | sed 's/^/║    /' | sed 's/$//' | awk '{printf "%-60s║\n", $0}'
    echo "║                                                          ║"
    echo "║  Update README.md and stage it, then commit again.      ║"
    echo "╚══════════════════════════════════════════════════════════╝"
    echo ""
    exit 1
fi

# ── Check 2: Version & date consistency (warnings only) ──────────────────────

VERSION=$(cat VERSION 2>/dev/null | tr -d '[:space:]')
TODAY=$(date +%Y-%m-%d)
WARN=0

if [ -n "$VERSION" ]; then
    if ! grep -q "Version $VERSION" README.md 2>/dev/null; then
        echo "⚠  README.md version does not match VERSION file ($VERSION)"
        WARN=1
    fi

    if ! grep -q "Latest version.*$VERSION" CHANGELOG.md 2>/dev/null; then
        echo "⚠  CHANGELOG.md latest version does not match VERSION file ($VERSION)"
        WARN=1
    fi
fi

if ! grep -q "Last updated.*$TODAY" README.md 2>/dev/null; then
    echo "⚠  README.md 'Last updated' date is not today ($TODAY)"
    WARN=1
fi

if [ "$WARN" -eq 1 ]; then
    echo ""
    echo "   Tip: update VERSION, README.md, and CHANGELOG.md before committing."
    echo "   See CLAUDE.md → 'Pre-Commit Checklist' for details."
    echo ""
fi

exit 0
